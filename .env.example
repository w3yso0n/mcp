MSSQL_SERVER=localhost,1433
MSSQL_DATABASE=master
MSSQL_USER=sa
MSSQL_PASSWORD=your_password_here

# Windows local (sin Driver 18): SQL Server
# Docker / Coolify / Linux: ODBC Driver 18 for SQL Server
# Auto-detecta el mejor driver instalado: auto
MSSQL_DRIVER=auto

MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_READONLY=true
MSSQL_QUERY_ROW_LIMIT=100
